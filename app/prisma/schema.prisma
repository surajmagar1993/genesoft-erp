// Prisma Schema for Genesoft ERP & CRM
// Multi-tenant SaaS with Row-Level Security

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================================
// MULTI-TENANT CORE
// ============================================

model Tenant {
  id           String   @id @default(cuid())
  name         String
  domain       String?  @unique
  countryCode  String   @default("IN") @map("country_code")
  currencyCode String   @default("INR") @map("currency_code")
  plan         Plan     @default(FREE)
  settings     Json     @default("{}")
  logoUrl      String?  @map("logo_url")
  address      Json?    
  phone        String?
  email        String?
  website      String?
  fiscalYearStart Int   @default(4) @map("fiscal_year_start") // April for India
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // Relations
  users        User[]
  contacts     Contact[]
  products     Product[]
  invoices     Invoice[]
  taxGroups    TaxGroup[]

  @@map("tenants")
}

enum Plan {
  FREE
  BASIC
  PRO
  ENTERPRISE
}

model User {
  id         String   @id @default(cuid())
  authId     String   @unique @map("auth_id") // Supabase Auth UUID
  tenantId   String   @map("tenant_id")
  role       Role     @default(USER)
  firstName  String   @map("first_name")
  lastName   String   @map("last_name")
  email      String
  phone      String?
  avatarUrl  String?  @map("avatar_url")
  isActive   Boolean  @default(true) @map("is_active")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  // Relations
  tenant     Tenant   @relation(fields: [tenantId], references: [id])

  @@map("users")
}

enum Role {
  SUPER_ADMIN
  ADMIN
  MANAGER
  USER
  VIEWER
}

// ============================================
// CRM & CONTACTS
// ============================================

model Contact {
  id              String       @id @default(cuid())
  tenantId        String       @map("tenant_id")
  type            ContactType  @default(INDIVIDUAL)
  customerGroup   String?      @map("customer_group") // retail, wholesale, vip
  
  // Basic Info
  firstName       String?      @map("first_name")
  lastName        String?      @map("last_name")
  companyName     String?      @map("company_name")
  displayName     String       @map("display_name")
  email           String?
  phone           String?
  mobile          String?
  website         String?
  
  // Address
  billingAddress  Json?        @map("billing_address")
  shippingAddress Json?        @map("shipping_address")
  
  // India Identifiers
  gstin           String?      // GST Number
  pan             String?      // PAN Card
  cin             String?      // Corporate ID
  tan             String?      // TDS Account
  msmeUdyam       String?      @map("msme_udyam")
  
  // UAE Identifiers
  trn             String?      // Tax Registration Number
  tradeLicense    String?      @map("trade_license")
  
  // Saudi Arabia Identifiers
  vatNumberKsa    String?      @map("vat_number_ksa")
  crNumber        String?      @map("cr_number")
  
  // USA Identifiers
  ein             String?      // Employer ID
  
  // Generic
  taxNumber       String?      @map("tax_number")
  countryCode     String?      @map("country_code")
  
  // Financial
  creditLimit     Decimal?     @map("credit_limit") @db.Decimal(15, 2)
  balance         Decimal      @default(0) @db.Decimal(15, 2)
  
  // Meta
  tags            Json         @default("[]")
  notes           String?
  isActive        Boolean      @default(true) @map("is_active")
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")

  // Relations
  tenant          Tenant       @relation(fields: [tenantId], references: [id])
  leads           Lead[]
  deals           Deal[]
  invoices        Invoice[]

  @@index([tenantId])
  @@index([tenantId, email])
  @@index([tenantId, gstin])
  @@map("contacts")
}

enum ContactType {
  INDIVIDUAL
  COMPANY
}

model Lead {
  id           String     @id @default(cuid())
  tenantId     String     @map("tenant_id")
  contactId    String?    @map("contact_id")
  title        String
  source       String?    // web_form, referral, cold_call
  status       LeadStatus @default(NEW)
  score        Int        @default(0)
  assignedTo   String?    @map("assigned_to")
  notes        String?
  convertedTo  String?    @map("converted_to") // deal_id
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  contact      Contact?   @relation(fields: [contactId], references: [id])

  @@index([tenantId])
  @@map("leads")
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  CONVERTED
  LOST
}

model Deal {
  id                String    @id @default(cuid())
  tenantId          String    @map("tenant_id")
  contactId         String    @map("contact_id")
  title             String
  value             Decimal?  @db.Decimal(15, 2)
  currency          String    @default("INR")
  stage             DealStage @default(PROSPECTING)
  probability       Int       @default(0) // 0-100
  expectedCloseDate DateTime? @map("expected_close_date")
  assignedTo        String?   @map("assigned_to")
  notes             String?
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  contact           Contact   @relation(fields: [contactId], references: [id])

  @@index([tenantId])
  @@map("deals")
}

enum DealStage {
  PROSPECTING
  QUALIFICATION
  PROPOSAL
  NEGOTIATION
  CLOSED_WON
  CLOSED_LOST
}

// ============================================
// PRODUCTS & SERVICES
// ============================================

model Product {
  id           String      @id @default(cuid())
  tenantId     String      @map("tenant_id")
  type         ProductType @default(PRODUCT)
  name         String
  sku          String?
  hsnSacCode   String?     @map("hsn_sac_code")
  description  String?
  unitPrice    Decimal     @default(0) @db.Decimal(15, 2)
  currency     String      @default("INR")
  unit         String      @default("Nos") // Nos, Kg, Ltr, Hr, etc.
  taxGroupId   String?     @map("tax_group_id")
  stockQty     Decimal     @default(0) @map("stock_qty") @db.Decimal(15, 2)
  imageUrl     String?     @map("image_url")
  isActive     Boolean     @default(true) @map("is_active")
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")

  tenant       Tenant      @relation(fields: [tenantId], references: [id])
  taxGroup     TaxGroup?   @relation(fields: [taxGroupId], references: [id])
  invoiceItems InvoiceItem[]

  @@index([tenantId])
  @@index([tenantId, sku])
  @@map("products")
}

enum ProductType {
  PRODUCT
  SERVICE
}

// ============================================
// TAX ENGINE
// ============================================

model TaxGroup {
  id          String    @id @default(cuid())
  tenantId    String    @map("tenant_id")
  name        String    // "GST 18%", "UAE VAT 5%", "Zero Rated"
  countryCode String    @map("country_code")
  isDefault   Boolean   @default(false) @map("is_default")
  isActive    Boolean   @default(true) @map("is_active")
  createdAt   DateTime  @default(now()) @map("created_at")

  tenant      Tenant    @relation(fields: [tenantId], references: [id])
  taxRates    TaxRate[]
  products    Product[]

  @@index([tenantId])
  @@map("tax_groups")
}

model TaxRate {
  id         String   @id @default(cuid())
  taxGroupId String   @map("tax_group_id")
  name       String   // "CGST", "SGST", "IGST", "VAT"
  rate       Decimal  @db.Decimal(5, 2) // percentage
  isActive   Boolean  @default(true) @map("is_active")

  taxGroup   TaxGroup @relation(fields: [taxGroupId], references: [id])

  @@map("tax_rates")
}

// ============================================
// INVOICING
// ============================================

model Invoice {
  id              String        @id @default(cuid())
  tenantId        String        @map("tenant_id")
  contactId       String        @map("contact_id")
  invoiceNumber   String        @map("invoice_number")
  type            InvoiceType   @default(TAX_INVOICE)
  status          InvoiceStatus @default(DRAFT)
  
  // Dates
  invoiceDate     DateTime      @default(now()) @map("invoice_date")
  dueDate         DateTime?     @map("due_date")
  
  // Addresses
  billTo          Json          @map("bill_to")
  shipTo          Json?         @map("ship_to")
  placeOfSupply   String?       @map("place_of_supply")
  
  // Amounts
  subtotal        Decimal       @default(0) @db.Decimal(15, 2)
  taxAmount       Decimal       @default(0) @map("tax_amount") @db.Decimal(15, 2)
  discount        Decimal       @default(0) @db.Decimal(15, 2)
  total           Decimal       @default(0) @db.Decimal(15, 2)
  totalInWords    String?       @map("total_in_words")
  currencyCode    String        @default("INR") @map("currency_code")
  
  // Tax Summary
  taxSummary      Json?         @map("tax_summary") // HSN/SAC breakup table
  
  // Payment & Terms
  paymentTerms    String?       @map("payment_terms")
  bankDetails     Json?         @map("bank_details")
  notes           String?
  terms           String?
  
  // Files
  signatureUrl    String?       @map("signature_url")
  pdfUrl          String?       @map("pdf_url")
  
  // Meta
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  // Relations
  tenant          Tenant        @relation(fields: [tenantId], references: [id])
  contact         Contact       @relation(fields: [contactId], references: [id])
  items           InvoiceItem[]

  @@unique([tenantId, invoiceNumber])
  @@index([tenantId])
  @@index([tenantId, status])
  @@map("invoices")
}

enum InvoiceType {
  TAX_INVOICE
  PROFORMA
  CREDIT_NOTE
  DEBIT_NOTE
}

enum InvoiceStatus {
  DRAFT
  SENT
  VIEWED
  PARTIALLY_PAID
  PAID
  OVERDUE
  CANCELLED
}

model InvoiceItem {
  id          String  @id @default(cuid())
  invoiceId   String  @map("invoice_id")
  productId   String? @map("product_id")
  description String
  hsnSacCode  String? @map("hsn_sac_code")
  quantity    Decimal @db.Decimal(15, 2)
  unitPrice   Decimal @map("unit_price") @db.Decimal(15, 2)
  
  // Tax breakdown
  cgstRate    Decimal? @map("cgst_rate") @db.Decimal(5, 2)
  cgstAmount  Decimal? @map("cgst_amount") @db.Decimal(15, 2)
  sgstRate    Decimal? @map("sgst_rate") @db.Decimal(5, 2)
  sgstAmount  Decimal? @map("sgst_amount") @db.Decimal(15, 2)
  igstRate    Decimal? @map("igst_rate") @db.Decimal(5, 2)
  igstAmount  Decimal? @map("igst_amount") @db.Decimal(15, 2)
  vatRate     Decimal? @map("vat_rate") @db.Decimal(5, 2)
  vatAmount   Decimal? @map("vat_amount") @db.Decimal(15, 2)
  
  // Totals
  discount    Decimal  @default(0) @db.Decimal(15, 2)
  lineTotal   Decimal  @map("line_total") @db.Decimal(15, 2)

  // Relations
  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  product     Product? @relation(fields: [productId], references: [id])

  @@map("invoice_items")
}
